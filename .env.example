# ─────────────────────────────────────────────────────────────────────────────
# Media Editor — Environment Variables Example
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── API server (Fastify) ──────────────────────────────────────────────────────
# Port the API listens on
PORT=4000

# Allowed CORS origin for the API (your Next.js web app)
WEB_ORIGIN=http://localhost:3000

# ── Web App (Next.js) ─────────────────────────────────────────────────────────
# URL the browser uses to call the API
# In Docker: use the service name  →  http://api:4000
# In local dev: use localhost       →  http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Remove.bg API (optional — for production-quality BG removal) ──────────────
# Sign up at https://www.remove.bg/api and paste your API key here.
# If left empty, the server will use the built-in sharp luminance method.
# REMOVE_BG_API_KEY=your_key_here

# ── Other AI integrations (future) ───────────────────────────────────────────
# OPENAI_API_KEY=sk-...
